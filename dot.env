# ------------------------------------------------------------------------------
# Expose selected process environment to the runtime environment.
# Secret data should NEVER set in any (YAML) config files that
# typically will be part of a git repo.
#
# Multi-platform by construction: Ruby's ENV works identically on macOS,
# Linux, *BSD and Windows. A '.env' file in the site root is loaded
# automatically when the 'dotenv' gem is available (load by default).
#
# Using a dot env file ensures that secret data never leaves the server.
#
# NOTE:
#  A productive dot env file '.env' is excluded (.gitignore) to be exposed
#  to any git repo.
#
# NOTE:
#  This is the standard pattern e.g. Anthropic itself recommends for
#  static sites.
#  The Anthropic docs describe 'anthropic-dangerous-direct-browser-access'
#  as "dangerous" for exactly this reason.
#
# Add as many env variables as required
# ------------------------------------------------------------------------------
#
VARIABLE1_NAME   = "value1"
VARIABLE2_NAME   = "value2"